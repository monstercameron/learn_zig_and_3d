root = true

[*.{zig,zon,md,json,py,txt}]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4

[*.ps1]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab

[*.{png,jpg,jpeg,bmp,exr,mp3,glb,obj,dll,exe}]
insert_final_newline = false